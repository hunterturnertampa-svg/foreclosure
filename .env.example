# Tracerfy
TRACERFY_API_KEY=

# Google Sheets webhook
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_TOKEN=

# Email alerts (Gmail App Password recommended)
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Behavior
SCRAPE_LOOKBACK_DAYS=7
BACKFILL_DAYS=7
BACKFILL_MAX_LOOKUPS=200
COURT_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Counties to scrape (comma-separated). Each county needs its own ARCGIS_* block below.
COUNTIES=Berkeley,Dorchester

# --- Berkeley ---
BERKELEY_ARCGIS_QUERY_URL=https://gis.berkeleycountysc.gov/arcgis/rest/services/API/CAD_API/MapServer/0/query
BERKELEY_ARCGIS_PIN_FIELD=O_TMS
BERKELEY_ARCGIS_OWNER_FIELD=OwnerName
BERKELEY_ARCGIS_ADDRESS_FIELD=GIS_Address
BERKELEY_ARCGIS_ADDRESS_FALLBACK_FIELD=StreetAddress1
BERKELEY_ARCGIS_CITY_FIELD=City
BERKELEY_ARCGIS_ZIP_FIELD=Zip
BERKELEY_ARCGIS_PIN_STRIP_DASHES=true

# --- Dorchester ---
DORCHESTER_ARCGIS_QUERY_URL=https://services.arcgis.com/ehmkfEMN55hUsomR/arcgis/rest/services/Parcels/FeatureServer/0/query
DORCHESTER_ARCGIS_PIN_FIELD=TMS13
DORCHESTER_ARCGIS_OWNER_FIELD=OWNER
DORCHESTER_ARCGIS_ADDRESS_FIELD=PROPERTY_LOCATION
DORCHESTER_ARCGIS_CSZ_FIELD=CITY_STATE_ZIP
DORCHESTER_ARCGIS_PIN_STRIP_DASHES=true

# Storage
SQLITE_PATH=data/bot.sqlite
